#!/usr/bin/env bash
# shrimpbot-bridge — Bridge Claude Code CLI to Feishu via ShrimpBot
set -euo pipefail

# Resolve ShrimpBot home directory
SHRIMPBOT_HOME="${SHRIMPBOT_HOME:-}"
if [ -z "$SHRIMPBOT_HOME" ]; then
  for candidate in "/opt/ShrimpBot" "$HOME/shrimpbot" "$HOME/ShrimpBot"; do
    if [ -f "$candidate/src/bridge/cli-bridge-entry.ts" ]; then
      SHRIMPBOT_HOME="$candidate"
      break
    fi
  done
fi

if [ -z "$SHRIMPBOT_HOME" ]; then
  echo "Error: Cannot find ShrimpBot installation"
  echo "Set SHRIMPBOT_HOME to the ShrimpBot installation directory"
  exit 1
fi

# Use tsx from ShrimpBot's node_modules to run TypeScript source directly
exec "$SHRIMPBOT_HOME/node_modules/.bin/tsx" "$SHRIMPBOT_HOME/src/bridge/cli-bridge-entry.ts" "$@"
